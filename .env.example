# Claude Code 環境変数の例
# このファイルを `.env` にコピーし、必要な変数のコメントを外して値を設定してください。
# `.env` 自体は .gitignore 対象（個人の設定）。

# ============================================================
# OpenTelemetry 観測性 (オプション)
# ============================================================
# Claude Code のメトリクス・ログを OTLP エンドポイントに送信
# 詳細: https://code.claude.com/docs/en/monitoring-usage
#
# 有効化するには以下のコメントを外す:
#
# CLAUDE_CODE_ENABLE_TELEMETRY=1
#
# # OTLP エクスポーター設定
# OTEL_METRICS_EXPORTER=otlp
# OTEL_LOGS_EXPORTER=otlp
# OTEL_EXPORTER_OTLP_PROTOCOL=grpc
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
#
# # エクスポート間隔 (ミリ秒)
# OTEL_METRIC_EXPORT_INTERVAL=60000
# OTEL_LOGS_EXPORT_INTERVAL=5000
#
# # 認証ヘッダー (必要に応じて)
# # OTEL_EXPORTER_OTLP_HEADERS=authorization=Bearer <token>

# ============================================================
# Claude Code 動作チューニング (オプション)
# ============================================================
# 自動コンパクションの閾値 (デフォルト 95%)
# CLAUDE_AUTOCOMPACT_PCT_OVERRIDE=60

# Bash デフォルトタイムアウト (ミリ秒)
# BASH_DEFAULT_TIMEOUT_MS=120000

# サブエージェントが使うモデルを上書き
# CLAUDE_CODE_SUBAGENT_MODEL=claude-sonnet-4-6

# ============================================================
# その他のサービス連携 (プロジェクトに応じて追加)
# ============================================================
# GITHUB_PERSONAL_ACCESS_TOKEN=
# ANTHROPIC_API_KEY=
