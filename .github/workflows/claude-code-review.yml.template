name: Claude Code Review

# PR が opened / synchronize / reopened されるたびに、Claude Code Action が
# 自動で差分レビューコメントを投稿する。
#
# 前提:
#   gh secret set ANTHROPIC_API_KEY  # GitHub repo に API キーを登録
#
# 有効化:
#   mv claude-code-review.yml.template claude-code-review.yml
#
# 一時無効化:
#   `on:` を `workflow_dispatch:` のみに変更（または本ファイル削除）
#
# 公式: https://code.claude.com/docs/ja/github-actions

on:
  pull_request:
    types: [opened, synchronize, reopened]

permissions:
  contents: read
  pull-requests: write

jobs:
  review:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout
        uses: actions/checkout@v4
        with:
          fetch-depth: 0

      - name: Run Claude Code Review
        uses: anthropics/claude-code-action@v1
        with:
          anthropic_api_key: ${{ secrets.ANTHROPIC_API_KEY }}
